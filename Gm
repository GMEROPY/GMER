<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portfolio - John Doe</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white text-gray-900 font-sans">

  <!-- Navigation -->
  <nav class="fixed top-0 w-full bg-white/80 backdrop-blur-sm border-b border-gray-200 z-50">
    <div class="container mx-auto px-6 py-4 flex justify-between items-center">
      <div class="text-xl font-bold text-blue-600">John Doe</div>
      <div class="hidden md:flex space-x-8">
        <a href="#home" class="nav-link text-gray-900 hover:text-blue-600">Home</a>
        <a href="#about" class="nav-link text-gray-900 hover:text-blue-600">About</a>
        <a href="#projects" class="nav-link text-gray-900 hover:text-blue-600">Projects</a>
        <a href="#contact" class="nav-link text-gray-900 hover:text-blue-600">Contact</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="home" class="min-h-screen flex items-center justify-center pt-20 pb-16 px-6">
    <div class="container mx-auto text-center max-w-3xl">
      <h1 class="text-4xl md:text-6xl font-bold mb-6">
        Hi, I'm <span class="text-blue-600">John Doe</span>
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 mb-8">
        Frontend Developer & UI/UX Designer
      </p>
      <p class="text-lg text-gray-600 mb-12">
        I create beautiful, functional, and user-centered digital experiences
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#projects" class="bg-blue-600 text-white px-8 py-3 rounded-lg hover:bg-blue-700 transition-colors font-medium">View My Work</a>
        <a href="#contact" class="border border-blue-600 text-blue-600 px-8 py-3 rounded-lg hover:bg-blue-600 hover:text-white transition-colors font-medium">Contact Me</a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-20 px-6 bg-gray-50">
    <div class="container mx-auto text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">About Me</h2>
      <div class="w-20 h-1 bg-blue-600 mx-auto"></div>
    </div>
    <div class="container mx-auto grid md:grid-cols-2 gap-12 items-center">
      <img src="https://via.placeholder.com/400x500?text=Professional+Portrait" alt="Professional portrait" class="rounded-lg shadow-lg w-full" />
      <div>
        <h3 class="text-2xl font-semibold mb-6">My Journey</h3>
        <p class="text-gray-600 mb-6">
          With over 5 years of experience in frontend development, I specialize in creating 
          responsive, accessible, and performant web applications.
        </p>
        <p class="text-gray-600 mb-8">
          I believe in continuous learning and staying updated with the latest technologies 
          and design trends.
        </p>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white p-4 rounded-lg shadow-sm">
            <div class="text-2xl font-bold text-blue-600 mb-2">50+</div>
            <div class="text-gray-600">Projects Completed</div>
          </div>
          <div class="bg-white p-4 rounded-lg shadow-sm">
            <div class="text-2xl font-bold text-blue-600 mb-2">5+</div>
            <div class="text-gray-600">Years Experience</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="py-20 px-6 bg-gray-50">
    <div class="container mx-auto text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Featured Projects</h2>
      <div class="w-20 h-1 bg-blue-600 mx-auto"></div>
    </div>
    <div class="container mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Project 1 -->
      <div class="bg-white rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
        <img src="https://via.placeholder.com/400x250?text=E-Commerce+Dashboard" class="w-full h-48 object-cover" />
        <div class="p-6">
          <h3 class="text-xl font-semibold mb-2">E-Commerce Platform</h3>
          <p class="text-gray-600 mb-4">A full-stack e-commerce solution with React, Node.js, and MongoDB</p>
        </div>
      </div>
      <!-- Project 2 -->
      <div class="bg-white rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
        <img src="https://via.placeholder.com/400x250?text=Banking+App" class="w-full h-48 object-cover" />
        <div class="p-6">
          <h3 class="text-xl font-semibold mb-2">Banking App</h3>
          <p class="text-gray-600 mb-4">Mobile banking application with secure transactions and analytics</p>
        </div>
      </div>
      <!-- Project 3 -->
      <div class="bg-white rounded-lg overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
        <img src="https://via.placeholder.com/400x250?text=Task+Manager" class="w-full h-48 object-cover" />
        <div class="p-6">
          <h3 class="text-xl font-semibold mb-2">Task Manager</h3>
          <p class="text-gray-600 mb-4">Productivity app with kanban boards, time tracking, and team collaboration</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 px-6 bg-white">
    <div class="container mx-auto text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Get In Touch</h2>
      <div class="w-20 h-1 bg-blue-600 mx-auto"></div>
      <p class="text-gray-600 mt-4 max-w-2xl mx-auto">
        I'm currently available for freelance work and open to new opportunities. 
        Let's discuss how we can work together!
      </p>
    </div>
  </section>

  <script>
    // Scroll spy for active nav link
    const links = document.querySelectorAll(".nav-link");
    const sections = document.querySelectorAll("section");

    window.addEventListener("scroll", () => {
      let current = "";
      sections.forEach(section => {
        const sectionTop = section.offsetTop - 100;
        if (scrollY >= sectionTop) {
          current = section.getAttribute("id");
        }
      });
      links.forEach(link => {
        link.classList.remove("text-blue-600");
        if (link.getAttribute("href") === "#" + current) {
          link.classList.add("text-blue-600");
        }
      });
    });
  </script>
</body>
</html>
